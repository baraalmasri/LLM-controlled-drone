{
  "name": "ROS2 Jazzy Drone Desktop Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/desktop-gui:1": {
      "version": "latest",
      "desktopType": "fluxbox"
    }
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Virtual Desktop GUI",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y python3-pip && pip3 install --upgrade pip"
}
